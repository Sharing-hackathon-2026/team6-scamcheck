# === Backend secrets & config ===
# Copy thành `.env` và điền giá trị thật. KHÔNG commit `.env`.

# Khóa API Google Gemini (mentor cấp cho hackathon; hoặc key test local).
GEMINI_API_KEY=

# Model dùng để phân tích. Test local: gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite

# Secret của Flask (sinh ngẫu nhiên: python -c "import secrets;print(secrets.token_hex(32))")
FLASK_SECRET_KEY=change-me

# Timeout từng lần Gemini, được backend clamp tối đa 8 giây.
GEMINI_TIMEOUT=8

# CORS: ở chế độ dev tách port (FE :5500, BE :5000) cần bật. Prod qua Nginx cùng origin thì KHÔNG cần.
# Cách dùng: CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
CORS_ORIGINS=

# SQLite dùng chung giữa các gunicorn worker: cache hash + lịch sử prompt/verdict theo session.
# Production dùng StateDirectory của systemd; local có thể đổi sang backend/instance/scamcheck.sqlite3.
SQLITE_PATH=/var/lib/scamcheck/scamcheck.sqlite3
CHECK_CACHE_CAPACITY=256
CHECK_CACHE_TTL=3600
AI_LOG_RETENTION_DAYS=30

# Login with exe: chỉ email trong allowlist mới xem universal stats/xuất toàn bộ log.
# Để rỗng = fail closed, không tài khoản nào có quyền admin.
ADMIN_ALLOWED_EMAILS=
ADMIN_AUTH_ORIGIN=https://team6-scamcheck.exe.xyz:8001
ADMIN_PROXY_PORT=8001

# Địa chỉ web công khai cho QR/thẻ cảnh báo Stage 5. Để rỗng khi dev (dùng same-origin).
# Production target: https://team6-scamcheck.exe.xyz/ (không thêm :8000; edge tự forward).
BASE_URL=
# Host QR được phép; production phải dùng HTTPS và nằm trong allowlist này.
SHARE_ALLOWED_HOSTS=team6-scamcheck.exe.xyz,localhost,127.0.0.1

# Kill switch riêng cho AI Người ứng cứu. false = vẫn trả playbook deterministic, không gọi AI.
RESCUE_AI_ENABLED=true
